# =============================================================================
# CouchHire — Environment Variables
# Copy this file to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Which provider to route LLM calls through. Options: groq | gemini | mistral | openrouter | anthropic | openai
LLM_PROVIDER=groq

# Only the key for your chosen provider needs to be set. Leave the others blank.
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=                   # Free: phone verify only at console.mistral.ai
OPENROUTER_API_KEY=                # Free: email only at openrouter.ai

# --- HuggingFace -------------------------------------------------------------
# Token for downloading gated models (sentence-transformers, spaCy, etc.)
# Get one at: https://huggingface.co/settings/tokens
# HF_TOKEN=

# --- Supabase ----------------------------------------------------------------
# Project URL and anon/public key from: Supabase → Settings → API
SUPABASE_URL=
SUPABASE_KEY=

# Management API access token — used ONLY by db/create_tables.py (one-off setup).
# Not needed at runtime. Get it from: Supabase → Settings → Access Tokens
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Direct Postgres connection string — used ONLY by db/create_tables.py (one-off setup).
# Not needed at runtime. Get it from: Supabase → Settings → Database → Connection string → URI
#
# ⚠️  IMPORTANT: Use the POOLER connection string, NOT the direct database host.
#     ✅ Correct: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#     ❌ Wrong:   postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
#
# ⚠️  If your password contains special characters (@ # % etc.), URL-encode them:
#     @ → %40    # → %23    % → %25
#     The script handles this automatically, but the Supabase dashboard URI should already be encoded.

# --- Telegram ----------------------------------------------------------------
# Bot token from @BotFather, chat ID from the getUpdates API endpoint
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Gmail MCP ---------------------------------------------------------------
# URL of your Gmail MCP server (Streamable HTTP transport)
# Example: http://localhost:8000/mcp (if running locally)
# See: https://github.com/taylorwilsdon/google_workspace_mcp
GMAIL_MCP_URL=http://localhost:8000/mcp

# Google OAuth credentials for the Gmail MCP server.
# Create at: https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Match Scorer ------------------------------------------------------------
# Jobs below this score are skipped. Integer 0–100.
MATCH_THRESHOLD=60

# --- GitHub ------------------------------------------------------------------
# Your GitHub profile URL — included in every email draft
GITHUB_URL=https://github.com/your-username

# --- Applicant Info ----------------------------------------------------------
# Your full name — used in email subject lines, cover letters, and resume
APPLICANT_NAME=Your Full Name

# Your email address — used in cover letter template and email drafts
APPLICANT_EMAIL=your.email@example.com

# --- Browser Agent / ATS Form Filling ----------------------------------------
# Chrome DevTools Protocol port for browser agent sessions.
# Default: 9222 — only change if that port is already in use.
# CDP_PORT=9222

# Run browser agent headless (no visible window). Default: false (visible for dev).
BROWSER_HEADLESS=false
# Persistent browser profile dir (cookies, sessions survive across runs)
# Default: ~/.couchhire/browser_profile/
# BROWSER_PROFILE_DIR=~/.couchhire/browser_profile/

# Your phone number — used to pre-fill ATS form fields
# APPLICANT_PHONE=

# Your LinkedIn profile URL — used to pre-fill ATS form fields
# APPLICANT_LINKEDIN=

# Path to persistent answer memory for ATS form fields.
# Default: cv/uploads/form_answers.json (gitignored)
# FORM_ANSWERS_PATH=cv/output/form_answers.json

# --- Job Search (JobSpy) -----------------------------------------------------
# Default job boards: indeed,linkedin,google,glassdoor,zip_recruiter,bayt,naukri
JOBSPY_SITES=indeed,linkedin,google,glassdoor
# Country for Indeed/Glassdoor (see README for full list)
JOBSPY_COUNTRY=India
# Proxies for rate-limit avoidance (optional, comma-separated: user:pass@host:port)
JOBSPY_PROXIES=
# Maximum age of job postings in hours (default: 72 = 3 days, use 168 for a week)
JOBSPY_HOURS_OLD=168
# Fetch full job descriptions from LinkedIn (slower but needed for scoring)
LINKEDIN_FETCH_DESCRIPTION=true
# Minimum match score to show in search results (0-100)
MIN_MATCH_SCORE=60.0
# Maximum results to show after filtering
MAX_SEARCH_RESULTS=10

# --- NLP Retraining ----------------------------------------------------------
# Minimum labeled outcomes before retraining is allowed
MIN_RETRAIN_LABELS=10
# Auto-retrain every N new labels (0 = manual only via dashboard/CLI)
RETRAIN_EVERY=10

# Output directory for generated resumes and cover letters.
# Files are saved as: OUTPUT_BASE_DIR/<Company>/<Role>/Resume.pdf and Cover Letter.pdf
# Defaults to cv/output/ if not set.
# OUTPUT_BASE_DIR=/path/to/your/output/directory
